# --- Firmware: copyrighted, NEVER commit (bring-your-own) ---
*.fls
*.mcu
*.ppm
*.pmm
flash/
firmware/
web/dct3.data
web/fw/
web/fiasco/
web/fiasco

# --- Build artifacts ---
build/
*.o
*.bc
*.wasm.map
# ...but DO commit the canonical web build so the demo runs without emscripten.
# (The firmware preload web/dct3.data is excluded above.)
!web/dct3.wasm
!web/dct3.js

# Content-addressed web assets (regenerated by `make all`)
web/asset-manifest.json
web/firmware-manifest.json
web/dct3.[0-9a-f]*.wasm
web/dct3.[0-9a-f]*.js
web/dct3.[0-9a-f]*.data
web/main.[0-9a-f]*.js

# Compiled nokix runner (build via tools/nokix/Makefile)
tools/nokix/nokix

# Live symbol scratch (mid-session findings). The archive IS committed.
tools/symbols/*.scratch.txt
!tools/symbols/*.scratch.archive.txt

# --- Python / toolchain / editors ---
__pycache__/
*.pyc
.vscode/
.idea/
*.swp
*.tmp
.DS_Store
